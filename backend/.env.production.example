# NAVPRO Backend — Production Environment Variables
# Copy this file to .env and fill in ALL values before deployment.
# NEVER commit the actual .env file to version control.

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://navpro:CHANGE_ME_STRONG_PASSWORD@postgres:5432/navpro_db

# ── JWT Secret ──────────────────────────────────────────────────────────────
# MINIMUM 64 characters, cryptographically random.
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_-base64_64

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated HTTPS origins. No trailing slashes.
# Example: https://navpro.company.com,https://www.navpro.company.com
CORS_ORIGIN=https://navpro.company.com

# ── Redis ────────────────────────────────────────────────────────────────────
# Format: redis://:password@host:6379
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ── MinIO / Object Store ──────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=navpro
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD_MIN_16_CHARS

# ── Row Level Security ────────────────────────────────────────────────────────
# ALWAYS set to true in production for data isolation between org units
NAVPRO_RLS_ENABLED=true

# ── Email (optional) ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.company.com
# SMTP_PORT=587
# SMTP_USER=navpro@company.com
# SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
# SMTP_FROM=noreply@company.com
