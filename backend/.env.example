PORT=4000
# PostgreSQL — ganti user/password/host sesuai lingkungan Anda (jangan commit .env)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/navpro_db
# Dev: string acak panjang. Production: wajib ≥32 karakter (openssl rand -base64 48)
JWT_SECRET=
# Hanya untuk `node src/seed.js` di mesin development lokal
SEED_DEMO_PASSWORD=
# Opsional — smoke test (`npm run smoke`)
SMOKE_EMAIL=
SMOKE_PASSWORD=
SMOKE_SA_EMAIL=
SMOKE_ASMAN_EMAIL=
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
